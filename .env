# Настройки базы данных
# Вместо PostgreSQL используем локальный файл SQLite
DATABASE_URL=sqlite:///./educational_platform.db

# Секретный ключ для токенов (любой набор букв)
SECRET_KEY=super_secret_key_123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Настройки приложения
APP_NAME=Educational Platform
APP_VERSION=1.0.0
DEBUG=True